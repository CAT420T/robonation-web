// --------------------------- screens/OutreachScreen.js ---------------------------
import React, { useState, useEffect } from "react";
import { View, Text, TextInput, Button, ScrollView, StyleSheet } from "react-native";
import { db } from "../firebase";
import { collection, addDoc, getDocs } from "firebase/firestore";

export default function OutreachScreen() {
  const [activities, setActivities] = useState([]);
  const [text, setText] = useState("");
  const fetchData = async () => { const snapshot = await getDocs(collection(db,"outreach")); setActivities(snapshot.docs.map(d=>d.data())); };
  useEffect(()=>{fetchData();},[]);
  const addItem=async()=>{if(!text)return; await addDoc(collection(db,"outreach"),{text}); setText(""); fetchData();};
  return (
    <View style={{flex:1,padding:20}}>
      <Text style={{fontSize:24,fontWeight:"bold",marginBottom:12}}>Outreach</Text>
      <Text style={{marginBottom:8}}>Impact: {activities.length} events, 0 countries</Text>
      <TextInput placeholder="Add event" value={text} onChangeText={setText} style={{borderWidth:1,marginBottom:8,padding:6,borderRadius:6}} />
      <Button title="Add Outreach" onPress={addItem} />
      <ScrollView style={{marginTop:12}}>{activities.map((a,i)=>(<Text key={i}>• {a.text}</Text>))}</ScrollView>
    </View>
  );
}

// --------------------------- screens/CommunityScreen.js ---------------------------
import React, { useState, useEffect } from "react";
import { View, TextInput, Button, ScrollView, Text } from "react-native";
import { db } from "../firebase";
import { collection, addDoc, onSnapshot } from "firebase/firestore";

export default function CommunityScreen() {
  const [msg,setMsg]=useState(""); const [msgs,setMsgs]=useState([]);
  useEffect(()=>{const unsub=onSnapshot(collection(db,"chat"),snap=>setMsgs(snap.docs.map(d=>d.data())));return unsub;},[]);
  const send=async()=>{if(!msg)return; await addDoc(collection(db,"chat"),{msg}); setMsg("");};
  return (
    <View style={{flex:1,padding:20}}>
      <TextInput placeholder="Say something..." value={msg} onChangeText={setMsg} style={{borderWidth:1,marginBottom:6,padding:6,borderRadius:6}}/>
      <Button title="Send" onPress={send}/>
      <ScrollView style={{marginTop:12}}>{msgs.map((m,i)=>(<Text key={i}>• {m.msg}</Text>))}</ScrollView>
    </View>
  );
}

