// --------------------------- screens/LessonsScreen.js ---------------------------
import React, { useState } from "react";
import { View, ScrollView, Text, Image, StyleSheet, TouchableOpacity } from "react-native";
import LessonCard from "../components/LessonCard";

const lessonsData = [
  { id: 1, title: "Programming Basics", description: "Learn coding concepts", difficulty: "Beginner", time: "30 min", image: require("../assets/programming.png") },
  { id: 2, title: "Hardware 101", description: "Learn hardware components", difficulty: "Beginner", time: "45 min", image: require("../assets/hardware.png") },
  { id: 3, title: "CAD Basics", description: "Design robots with CAD", difficulty: "Intermediate", time: "40 min", image: require("../assets/cad.png") },
  { id: 4, title: "Outreach Skills", description: "Learn outreach techniques", difficulty: "Beginner", time: "25 min", image: require("../assets/outreach.png") }
];

export default function LessonsScreen() {
  const [filter, setFilter] = useState("All");

  const filteredLessons = filter === "All" ? lessonsData : lessonsData.filter(l => l.title.includes(filter));

  return (
    <ScrollView style={{ padding: 20 }}>
      <Text style={{ fontSize: 24, fontWeight: "bold", marginBottom: 10 }}>Lessons</Text>
      <View style={{ flexDirection: "row", marginBottom: 12 }}>
        {["All","Programming","Hardware","CAD","Outreach"].map((f,i)=>(
          <TouchableOpacity key={i} onPress={()=>setFilter(f)} style={{ marginRight: 8, padding: 6, backgroundColor: filter===f?"#4a90e2":"#ccc", borderRadius: 6 }}>
            <Text style={{ color: "#fff" }}>{f}</Text>
          </TouchableOpacity>
        ))}
      </View>
      {filteredLessons.map((l) => (<LessonCard key={l.id} lesson={l} />))}
    </ScrollView>
  );
}

